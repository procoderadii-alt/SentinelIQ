# SentinelIQ Configuration Example

# Backend Database Connection
DATABASE_URL=sqlite:///./sentineliq.db

# JWT Configuration
SECRET_KEY=generate_a_secure_random_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=720

# CORS Configuration
# Must be set to the exact deployed frontend origin(s) in production (never *)
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://localhost

# Rate Limiting
# Use to configure write and upload limits
# DEMO / LOW-RESOURCE PROFILE
# Recommended smaller values for a fast hackathon demo:
# SEED_CRIMES=500
# SEED_OFFENDERS=200
# SEED_DISTRICTS=20
# SEED_GANGS=50
# SEED_EMERGENCY_CALLS=500
# SEED_CCTV_EVENTS=500
RATE_LIMIT_WRITE=30/minute
RATE_LIMIT_UPLOAD=5/minute
RATE_LIMIT_COPILOT=10/minute

# Max Upload Size (in bytes, default 10MB)
MAX_UPLOAD_SIZE=10485760

# Seeding configuration
# Set to 'true' to explicitly seed the database on startup
SEED_ON_STARTUP=false
